rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 0. GLOBAL SAFETY NET
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // PHASE 3: PRIMITIVE HELPERS
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // High security: require email verification for writes
    // RELAXED: Use isOwner for now to avoid blocking users with unverified emails
    function isVerifiedOwner(userId) {
      return isOwner(userId);
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "victor@materialg.com" ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ==========================================
    // VALIDATION BLUEPRINTS
    // ==========================================

    function isValidUserProfile(data) {
      return (!('uid' in data) || data.uid == request.auth.uid)
        && (!('email' in data) || (data.email is string && data.email.size() <= 256))
        && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128))
        && (!('age' in data) || (data.age is number && data.age >= 0 && data.age <= 150))
        && (!('height' in data) || (data.height is number && data.height >= 0 && data.height <= 300))
        && (!('gender' in data) || (data.gender in ['male', 'female', 'other']))
        && (!('activityLevel' in data) || (data.activityLevel in ['sedentary', 'light', 'moderate', 'active', 'very_active']))
        && (!('goalBodyFat' in data) || (data.goalBodyFat is number && data.goalBodyFat >= 3 && data.goalBodyFat <= 60))
        && (!('currentWeight' in data) || (data.currentWeight is number && data.currentWeight >= 50 && data.currentWeight <= 1000))
        && (!('currentBodyFat' in data) || (data.currentBodyFat is number && data.currentBodyFat >= 3 && data.currentBodyFat <= 60))
        && (!('targetDate' in data) || (data.targetDate is string))
        && (!('activeMealPlanId' in data) || (data.activeMealPlanId is string || data.activeMealPlanId == null))
        && (!('activeWorkoutId' in data) || (data.activeWorkoutId is string || data.activeWorkoutId == null))
        && (!('photoURL' in data) || (data.photoURL is string || data.photoURL == null))
        && (!('createdAt' in data) || (data.createdAt is string))
        && (!('updatedAt' in data) || (data.updatedAt is string));
    }

    function isValidVitalLog(data) {
      return (!('date' in data) || (data.date is string && data.date.size() <= 64))
        && (!('weight' in data) || (data.weight is number && data.weight > 0 && data.weight < 1000))
        && (!('bodyFat' in data) || (data.bodyFat is number && data.bodyFat >= 0 && data.bodyFat <= 100))
        && (!('muscleMass' in data) || (data.muscleMass is number && data.muscleMass >= 0))
        && (!('updatedAt' in data) || (data.updatedAt is string));
    }

    function isValidFoodBankItem(data) {
      return (!('name' in data) || (data.name is string && data.name.size() <= 128))
        && (!('calories' in data) || (data.calories is number && data.calories >= 0 && data.calories <= 100000))
        && (!('protein' in data) || (data.protein is number && data.protein >= 0))
        && (!('carbs' in data) || (data.carbs is number && data.carbs >= 0))
        && (!('fats' in data) || (data.fats is number && data.fats >= 0))
        && (!('servingSize' in data) || (data.servingSize is number && data.servingSize >= 0))
        && (!('servingUnit' in data) || (data.servingUnit in ['g', 'oz', 'unit', 'ml']))
        && (!('mealTypes' in data) || (data.mealTypes is list && data.mealTypes.size() <= 3))
        && (!('updatedAt' in data) || (data.updatedAt is string));
    }

    function isValidMealPlan(data) {
      return data.keys().hasAll(['weekStartDate', 'days'])
        && data.weekStartDate is string
        && data.days is list && data.days.size() <= 14;
    }

    function isValidWorkoutPlan(data) {
      return data.keys().hasAll(['weekStartDate', 'days'])
        && data.weekStartDate is string
        && data.days is list && data.days.size() <= 14;
    }

    function isValidGroceryList(data) {
      return data.keys().hasAll(['weekStartDate', 'items'])
        && data.items is list && data.items.size() <= 200;
    }

    function isValidDailyTarget(data) {
      return data.keys().hasAll(['date', 'dailyCalories', 'macros'])
        && data.dailyCalories is number && data.dailyCalories > 0
        && data.macros is map;
    }

    // ==========================================
    // 4. RESOURCE MATCHES
    // ==========================================

    match /users/{userId} {
      // Profile
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isVerifiedOwner(userId) && isValidUserProfile(incoming());
      allow update: if isVerifiedOwner(userId) && isValidUserProfile(incoming());

      // Vitals
      match /vitals/{vitalId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isVerifiedOwner(userId) && isValidId(vitalId) && isValidVitalLog(incoming());
        allow update: if isVerifiedOwner(userId) && isValidVitalLog(incoming());
        allow delete: if isVerifiedOwner(userId) || isAdmin();
      }

      // Meal Plans
      match /mealPlans/{planId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isVerifiedOwner(userId) && isValidId(planId) && isValidMealPlan(incoming());
        allow update: if isVerifiedOwner(userId) && isValidId(planId) && isValidMealPlan(incoming());
        allow delete: if isVerifiedOwner(userId) || isAdmin();
      }

      // Food Bank
      match /foodBank/{itemId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isVerifiedOwner(userId) && isValidId(itemId) && isValidFoodBankItem(incoming());
        allow update: if isVerifiedOwner(userId) && isValidId(itemId) && isValidFoodBankItem(incoming());
        allow delete: if isVerifiedOwner(userId) || isAdmin();
      }

      // Grocery Lists
      match /groceryLists/{listId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isVerifiedOwner(userId) && isValidId(listId) && isValidGroceryList(incoming());
        allow update: if isVerifiedOwner(userId) && isValidId(listId) && isValidGroceryList(incoming());
        allow delete: if isVerifiedOwner(userId) || isAdmin();
      }

      // Workouts
      match /workouts/{workoutId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isVerifiedOwner(userId) && isValidId(workoutId) && isValidWorkoutPlan(incoming());
        allow update: if isVerifiedOwner(userId) && isValidId(workoutId) && isValidWorkoutPlan(incoming());
        allow delete: if isVerifiedOwner(userId) || isAdmin();
      }

      // Daily Targets
      match /dailyTargets/{targetId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isVerifiedOwner(userId) && isValidId(targetId) && isValidDailyTarget(incoming());
        allow update: if isAdmin(); // Users shouldn't need to update snapshots
        allow delete: if isAdmin();
      }
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
